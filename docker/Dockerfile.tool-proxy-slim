# Thin runtime image for nucleus-tool-proxy.
#
# Requires a pre-compiled binary copied into the build context:
#   cp target/x86_64-unknown-linux-musl/release/nucleus-tool-proxy docker/
#   docker build -f docker/Dockerfile.tool-proxy-slim -t nucleus-tool-proxy:latest docker/
#   rm docker/nucleus-tool-proxy

FROM debian:bookworm-slim@sha256:74d56e3931e0d5a1dd51f8c8a2466d21de84a271cd3b5a733b803aa91abf4421

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    nodejs \
    npm \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Install CLI globally via lockfile for hash-pinned supply chain integrity.
# The lockfile in cli-pins/ contains npm integrity hashes verified by `npm ci`.
COPY cli-pins/package.json cli-pins/package-lock.json /tmp/cli-pins/
RUN cd /tmp/cli-pins && npm ci --ignore-scripts \
    && npm install -g /tmp/cli-pins/node_modules/@anthropic-ai/claude-code \
    && rm -rf /tmp/cli-pins

COPY nucleus-tool-proxy /usr/local/bin/
RUN chmod +x /usr/local/bin/nucleus-tool-proxy

RUN useradd -m -s /bin/bash -u 1000 agent
USER agent
WORKDIR /workspace

ENTRYPOINT ["nucleus-tool-proxy", "--listen", "0.0.0.0:8080"]
